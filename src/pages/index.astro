---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal';
import Hero from '../sections/Hero.astro';
import PullQuoteSection from '../sections/PullQuoteSection.astro';
import SignatureBakes from '../sections/SignatureBakes.astro';
import CoffeeMatcha from '../sections/CoffeeMatcha.astro';
import TheFamily from '../sections/TheFamily.astro';
import Press from '../sections/Press.astro';
import VisitTeaser from '../sections/VisitTeaser.astro';
---

<BaseLayout
  title="Didi's Cafe & Bakery | Artisan Pastries with Malaysian Souls | Wangsa Maju"
  description="Family-run bakery in Wangsa Maju. European pastries with Malaysian flavors — rendang croizza, masak lemak ciabatta, ondeh-ondeh croissants. Specialty coffee & matcha. Halal. Closed Mondays."
>
  <Hero />

  <ScrollReveal client:visible>
    <PullQuoteSection />
  </ScrollReveal>

  <ScrollReveal client:visible delay={100}>
    <SignatureBakes />
  </ScrollReveal>

  <ScrollReveal client:visible delay={100}>
    <CoffeeMatcha />
  </ScrollReveal>

  <ScrollReveal client:visible delay={100}>
    <TheFamily />
  </ScrollReveal>

  <ScrollReveal client:visible delay={100}>
    <Press />
  </ScrollReveal>

  <ScrollReveal client:visible delay={100}>
    <VisitTeaser />
  </ScrollReveal>
</BaseLayout>
