import SignatureBakes from '../sections/SignatureBakes.astro';
import CoffeeMatcha from '../sections/CoffeeMatcha.astro';
import TheFamily from '../sections/TheFamily.astro';
import Press from '../sections/Press.astro';
import VisitTeaser from '../sections/VisitTeaser.astro';
---

<BaseLayout
  title="Didi's Cafe & Bakery | Artisan Pastries with Malaysian Souls | Wangsa Maju"
