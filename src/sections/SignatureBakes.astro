---
import SectionHeading from '../components/SectionHeading.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import bakes from '../data/bakes.json';

const featured = bakes.items.filter((item) => item.featured).slice(0, 4);
const variants = ['cupcake', 'donut', 'icecream', 'lollipop', 'cherry', 'whip'] as const;
const tilts = ['tilt-left', 'tilt-right', 'tilt-left', 'tilt-right'];
const bgs = ['#ffb3c8', '#c8e8d4', '#ffe79e', '#cdd9ff'];
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <!-- decorative blob -->
  <div aria-hidden="true" class="cloud-blob" style="background:#ffe79e; width:300px; height:300px; top:-40px; right:10%;"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <SectionHeading
      eyebrow="What we're known for"
      title="A short list. We'd rather do a few things, properly."
      class="mb-14 md:mb-20"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      {featured.map((item, i) => (
        <a
          href="/bakes"
          class={`group block ${tilts[i % tilts.length]} hover:rotate-0 transition-transform duration-500`}
        >
          <div class="candy-card overflow-hidden">
            <div class="aspect-[4/5] relative">
              <ImagePlaceholder
                class="absolute inset-0 w-full h-full"
                variant={variants[i % variants.length]}
                caption={item.name.toLowerCase()}
                bg={bgs[i % bgs.length]}
              />
            </div>
            <div class="p-5 space-y-2 bg-white">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-display text-2xl text-[#4a2e22] group-hover:text-[#cf3a4e] transition-colors duration-300">
                  {item.name}
                </h3>
                <span class="text-sm font-bold text-[#4a2e22] tabular-nums whitespace-nowrap bg-[#ffd66e] px-2.5 py-1 rounded-full border-2 border-[#4a2e22]">
                  RM{item.price}
                </span>
              </div>
              <p class="text-sm text-[#6e4f3f] leading-relaxed line-clamp-2 font-medium">
                {item.description}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
