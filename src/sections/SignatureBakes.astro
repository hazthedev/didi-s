---
import SectionHeading from '../components/SectionHeading.astro';
import bakes from '../data/bakes.json';

const featured = bakes.items.filter((item) => item.featured).slice(0, 4);
---

<section class="bg-off-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <SectionHeading
      eyebrow="What we're known for"
      title="A short list. We'd rather do a few things, properly."
      class="mb-12 md:mb-16"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {featured.map((item) => (
        <a
          href="/bakes"
          class="group block bg-cream overflow-hidden transition-shadow duration-500 hover:shadow-lg"
        >
          <div class="aspect-[4/5] overflow-hidden relative">
            <img
              src={item.image.replace('/images/bakes/', 'https://images.unsplash.com/photo-') + '?w=600&h=750&fit=crop&q=80'}
              alt={item.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-[1.04]"
              loading="lazy"
              decoding="async"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0 bg-cream flex flex-col items-center justify-center gap-3 z-[-1]">
              <div class="w-10 h-10 rounded-full border-2 border-dashed border-sienna/25 flex items-center justify-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A85D3A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3c-4.5 0-8 3.5-8 8 0 5.25 8 10 8 10s8-4.75 8-10c0-4.5-3.5-8-8-8z"/>
                  <circle cx="12" cy="11" r="2.5"/>
                </svg>
              </div>
              <span class="font-accent text-sienna text-xs">fresh from the oven soon</span>
            </div>
          </div>
          <div class="p-5 space-y-2">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-display text-xl font-semibold text-espresso group-hover:text-sienna transition-colors duration-300">
                {item.name}
              </h3>
              <span class="text-sm text-mocha font-medium tabular-nums whitespace-nowrap">
                RM{item.price}
              </span>
            </div>
            <p class="text-sm text-mocha leading-relaxed line-clamp-2">
              {item.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
