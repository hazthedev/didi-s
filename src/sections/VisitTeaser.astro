---
import site from '../data/site.json';
import Button from '../components/Button.astro';

const todayName = new Date().toLocaleDateString('en-MY', { weekday: 'long' }).toLowerCase();
const todayHours = site.hours[todayName as keyof typeof site.hours];
const isClosed = todayHours?.closed ?? false;

function formatHours(hours: typeof todayHours) {
  if (!hours || hours.closed) return 'Closed';
  return `${hours.open} – ${hours.close}`;
}
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <div aria-hidden="true" class="cloud-blob" style="background:#ffe79e; width:300px; height:300px; bottom:-60px; right:10%;"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Map preview -->
      <div class="h-[45vh] lg:h-[55vh] candy-card overflow-hidden tilt-left hover:rotate-0 transition-transform duration-500 bg-[#fff4ee]">
        <iframe
          src={site.mapsEmbed}
          title="Didi's Cafe location map"
          class="w-full h-full border-0"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

      <!-- Info -->
      <div class="space-y-8">
        <div class="space-y-3">
          <p class="eyebrow">Visit Us</p>
          <h2 class="font-display text-4xl md:text-5xl text-[#4a2e22]">See you <span class="wavy">soon</span>.</h2>
        </div>

        <div class="candy-card bg-white p-6 space-y-3">
          <div class="flex items-center justify-between pb-3 border-b-2 border-dashed border-[#4a2e22]/30">
            <span class="text-sm font-bold text-[#4a2e22] capitalize">Today ({todayName})</span>
            <span class={`text-sm font-bold px-3 py-1 rounded-full border-2 border-[#4a2e22] ${isClosed ? 'bg-[#ffb3c8]' : 'bg-[#c8e8d4]'} text-[#4a2e22]`}>
              {formatHours(todayHours)}
            </span>
          </div>
          <p class="text-xs text-[#6e4f3f] font-medium">
            Closed Mondays — that's when we rest, plan, and prep the week's bakes.
          </p>
        </div>

        <address class="not-italic text-[#4a2e22] text-base leading-relaxed space-y-1 font-medium">
          <p class="flex items-center gap-2">
            <span aria-hidden="true">📍</span>{site.address.street}
          </p>
          <p class="pl-6">{site.address.area}, {site.address.postcode} {site.address.city}</p>
        </address>

        <div class="flex flex-wrap gap-4">
          <Button href="/story#visit" variant="filled" size="md">
            Plan Your Visit
          </Button>
          <Button href={`https://wa.me/${site.whatsapp}`} variant="outline" size="md" target="_blank" rel="noopener">
            WhatsApp Us
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
