---
import press from '../data/press.json';
---

<section class="bg-cream py-16 md:py-20 border-y border-espresso/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      {press.map((item) => (
        <div class="space-y-3">
          <h3 class="font-display text-lg font-semibold text-espresso">{item.name}</h3>
          <p class="text-sm text-mocha leading-relaxed italic">
            "{item.quote}"
          </p>
          <a
            href={item.url}
            target="_blank"
            rel="noopener"
            class="text-xs text-sienna hover:text-espresso transition-colors inline-flex items-center gap-1"
          >
            Read review
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
