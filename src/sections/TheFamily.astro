---
import SectionHeading from '../components/SectionHeading.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <div aria-hidden="true" class="cloud-blob" style="background:#ffb3c8; width:300px; height:300px; top:-60px; right:-60px;"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Photo -->
      <div class="h-[55vh] lg:h-[65vh] relative">
        <div class="candy-card overflow-hidden h-full tilt-right hover:rotate-0 transition-transform duration-500">
          <ImagePlaceholder
            class="w-full h-full"
            variant="cherry"
            caption="run with love"
            bg="#ffe79e"
          />
        </div>
        <!-- Star sticker -->
        <div class="absolute -bottom-4 -left-4 z-10 animate-wobble">
          <svg width="84" height="84" viewBox="0 0 84 84" aria-hidden="true">
            <circle cx="42" cy="42" r="36" fill="#cdd9ff" stroke="#4a2e22" stroke-width="3"/>
            <text x="42" y="38" text-anchor="middle" font-family="Caveat,cursive" font-size="14" font-weight="700" fill="#4a2e22">made by</text>
            <text x="42" y="56" text-anchor="middle" font-family="Caprasimo,serif" font-size="16" fill="#cf3a4e">family</text>
          </svg>
        </div>
      </div>

      <!-- Text -->
      <div class="space-y-6">
        <SectionHeading
          eyebrow="The Family"
          title="Run by the people who eat here too."
        />
        <div class="space-y-4 text-[#6e4f3f] leading-relaxed font-medium">
          <p>
            Didi's is Nashilla, her mom Noor Shida, and a small team of bakers who treat every loaf like it's going to their own table. You'll often find Noor Shida at the front, coffee in hand, asking how your day's been. <span class="text-[#cf3a4e] font-bold wavy">She means it.</span>
          </p>
          <p>
            Nashilla left law to build something her family could gather around. The name "Didi" — elder sister in Hindi — was her childhood nickname. Now it's the name on the door, and the feeling inside.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
