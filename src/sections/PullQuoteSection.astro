---
import PullQuote from '../components/PullQuote.astro';
---

<section class="relative py-20 md:py-28 lg:py-32 overflow-hidden">
  <div aria-hidden="true" class="cloud-blob" style="background:#ffb3c8; width:340px; height:340px; top:10%; left:-100px;"></div>
  <div aria-hidden="true" class="cloud-blob" style="background:#cdd9ff; width:280px; height:280px; bottom:0; right:-80px;"></div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <!-- decorative sprinkles -->
    <div class="flex justify-center gap-3 mb-8" aria-hidden="true">
      <span class="inline-block w-3 h-1 rounded-full bg-[#ff7a8a] rotate-12"></span>
      <span class="inline-block w-3 h-1 rounded-full bg-[#ffd66e] -rotate-12"></span>
      <span class="inline-block w-3 h-1 rounded-full bg-[#b9d28a] rotate-45"></span>
      <span class="inline-block w-3 h-1 rounded-full bg-[#cdd9ff] -rotate-45"></span>
      <span class="inline-block w-3 h-1 rounded-full bg-[#ff7a8a] rotate-12"></span>
    </div>
    <PullQuote
      quote="All of this started because our entire family loves coffee."
      attribution="Nashilla, founder · former lawyer, mum"
    />
  </div>
</section>
