---
import Button from '../components/Button.astro';
import site from '../data/site.json';

const today = new Date().toLocaleDateString('en-MY', { weekday: 'long' }).toLowerCase();
const isClosedToday = site.hours[today as keyof typeof site.hours]?.closed ?? false;
---

<section class="relative bg-off-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center min-h-[calc(100vh-5rem)] lg:min-h-[calc(100vh-5rem)]">
      <!-- Text -->
      <div class="py-12 lg:py-20 space-y-8 animate-fade-in-slow">
        <p class="eyebrow text-sienna font-medium">
          Wangsa Maju · Bakery · Cafe
        </p>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold text-espresso leading-[1.1]">
          Pastries with a passport.
        </h1>
        <p class="text-mocha text-lg md:text-xl max-w-lg leading-relaxed">
          European bakes, Malaysian souls. Made fresh every morning by family — the way it should be.
        </p>
        <div class="flex flex-wrap gap-4 pt-2">
          <Button href="/bakes" variant="filled" size="md">
            See What's Baking
          </Button>
          <Button href="/story#visit" variant="outline" size="md">
            Visit Us
          </Button>
        </div>
        {isClosedToday && (
          <p class="text-sm text-sienna font-medium">
            Closed today (Monday) — we reopen Tuesday at 9am.
          </p>
        )}
      </div>

      <!-- Photo -->
      <div class="relative h-[50vh] lg:h-[70vh] animate-scale-settle">
        <div class="relative w-full h-full">
          <img
            src="https://images.unsplash.com/photo-1555507036-ab1f4038024f?w=800&h=1000&fit=crop&q=85"
            alt="A golden, flaky croissant on a marble surface, warm bakery lighting"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            decoding="async"
            onerror="this.style.display='none'"
          />
          <div class="absolute inset-0 bg-cream flex flex-col items-center justify-center gap-3 z-[-1]">
            <div class="w-12 h-12 rounded-full border-2 border-dashed border-sienna/25 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#A85D3A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3c-4.5 0-8 3.5-8 8 0 5.25 8 10 8 10s8-4.75 8-10c0-4.5-3.5-8-8-8z"/>
                <circle cx="12" cy="11" r="2.5"/>
              </svg>
            </div>
            <span class="font-accent text-sienna text-sm">fresh from the oven soon</span>
          </div>
        </div>
        <div class="absolute bottom-6 right-6 lg:bottom-10 lg:right-10 transform -rotate-3">
          <span class="font-accent text-2xl md:text-3xl text-sienna bg-cream/90 px-4 py-2 shadow-sm">
            fresh today
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
