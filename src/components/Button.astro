---
export interface Props {
  href?: string;
  variant?: 'filled' | 'outline' | 'text';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = 'filled',
  size = 'md',
  type = 'button',
  target,
  rel,
  class: className = '',
} = Astro.props;

const baseStyles = 'candy-pill inline-flex items-center justify-center font-bold tracking-wide';

const variantStyles = {
  filled: 'bg-[#ff7a8a] text-[#fff4ee] hover:bg-[#ffd66e] hover:text-[#4a2e22]',
  outline: 'bg-[#fff4ee] text-[#4a2e22] hover:bg-[#c8e8d4]',
  text: 'bg-transparent text-[#cf3a4e] border-transparent shadow-none hover:text-[#4a2e22] underline-offset-4 hover:underline',
};

const sizeStyles = {
  sm: 'px-5 py-2 text-sm',
  md: 'px-7 py-3 text-sm',
  lg: 'px-9 py-4 text-base',
};

const classes = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;
---

{href ? (
  <a href={href} target={target} rel={rel} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
