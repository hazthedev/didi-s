---
export interface Props {
  quote: string;
  attribution?: string;
  class?: string;
}

const { quote, attribution, class: className = '' } = Astro.props;
---

<blockquote class={`space-y-5 ${className}`}>
  <p class="font-display text-3xl md:text-4xl lg:text-5xl text-[#4a2e22] leading-[1.15]">
    <span class="text-[#cf3a4e]">"</span>{quote}<span class="text-[#cf3a4e]">"</span>
  </p>
  {attribution && (
    <footer class="font-accent text-[#cf3a4e] text-xl md:text-2xl font-bold">
      — {attribution}
    </footer>
  )}
</blockquote>
