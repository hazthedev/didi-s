---
import site from '../data/site.json';

const currentYear = new Date().getFullYear();

const hours = [
  { day: 'Mon', label: 'Monday', ...site.hours.monday },
  { day: 'Tue', label: 'Tuesday', ...site.hours.tuesday },
  { day: 'Wed', label: 'Wednesday', ...site.hours.wednesday },
  { day: 'Thu', label: 'Thursday', ...site.hours.thursday },
  { day: 'Fri', label: 'Friday', ...site.hours.friday },
  { day: 'Sat', label: 'Saturday', ...site.hours.saturday },
  { day: 'Sun', label: 'Sunday', ...site.hours.sunday },
];
---

<footer class="relative bg-[#4a2e22] text-[#fff4ee] mt-20 overflow-hidden">
  <!-- top scallop edge -->
  <svg class="block w-full h-6 -mt-1" viewBox="0 0 1200 24" preserveAspectRatio="none" aria-hidden="true">
    <path d="M 0 24 Q 30 0 60 12 T 120 12 T 180 12 T 240 12 T 300 12 T 360 12 T 420 12 T 480 12 T 540 12 T 600 12 T 660 12 T 720 12 T 780 12 T 840 12 T 900 12 T 960 12 T 1020 12 T 1080 12 T 1140 12 T 1200 12 L 1200 24 Z" fill="#4a2e22"/>
  </svg>
  <!-- background sprinkles -->
  <div aria-hidden="true" class="absolute inset-0 opacity-15 pointer-events-none">
    <svg class="w-full h-full" preserveAspectRatio="xMidYMid slice" viewBox="0 0 600 400">
      <g stroke-width="3" stroke-linecap="round">
        <line x1="40"  y1="60"  x2="50"  y2="72"  stroke="#ff7a8a"/>
        <line x1="120" y1="180" x2="130" y2="190" stroke="#ffd66e"/>
        <line x1="500" y1="80"  x2="514" y2="92"  stroke="#b9d28a"/>
        <line x1="540" y1="280" x2="552" y2="292" stroke="#cdd9ff"/>
        <line x1="220" y1="320" x2="232" y2="330" stroke="#ff7a8a"/>
        <line x1="380" y1="220" x2="392" y2="232" stroke="#ffd66e"/>
      </g>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="font-display text-4xl text-[#ffd66e] inline-block hover-jelly">Didi's</a>
        <p class="text-[#fff4ee]/85 text-sm leading-relaxed max-w-xs font-medium">
          European bakes, Malaysian souls. Made fresh every morning by family in Wangsa Maju.
        </p>
        <p class="text-xs text-[#ffb3c8] font-bold tracking-widest uppercase">
          Halal · Closed Mondays
        </p>
      </div>

      <!-- Hours -->
      <div class="space-y-4">
        <h3 class="font-display text-2xl text-[#ffd66e]">Hours</h3>
        <ul class="space-y-2 text-sm">
          {hours.map((h) => (
            <li class="flex justify-between gap-4 font-medium">
              <span class={h.closed ? 'text-[#ffb3c8] font-bold' : 'text-[#fff4ee]/90'}>
                {h.day}
              </span>
              <span class={h.closed ? 'text-[#ffb3c8] font-bold' : 'text-[#fff4ee]/70'}>
                {h.closed ? 'Closed' : `${h.open} – ${h.close}`}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="space-y-4">
        <h3 class="font-display text-2xl text-[#ffd66e]">Find Us</h3>
        <address class="not-italic text-sm text-[#fff4ee]/85 leading-relaxed space-y-1 font-medium">
          <p>{site.address.street}</p>
          <p>{site.address.area}, {site.address.postcode} {site.address.city}</p>
        </address>
        <p class="text-sm font-medium">
          <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="text-[#fff4ee]/90 hover:text-[#ffd66e] transition-colors">
            {site.phone}
          </a>
        </p>
        <div class="flex flex-wrap items-center gap-2 pt-2">
          <a href={site.social.instagram} target="_blank" rel="noopener" class="candy-pill bg-[#ff7a8a] text-[#4a2e22] text-xs font-bold px-3 py-1.5">
            Instagram
          </a>
          <a href={site.social.tiktok} target="_blank" rel="noopener" class="candy-pill bg-[#cdd9ff] text-[#4a2e22] text-xs font-bold px-3 py-1.5">
            TikTok
          </a>
          <a href={site.social.foodpanda} target="_blank" rel="noopener" class="candy-pill bg-[#b9d28a] text-[#4a2e22] text-xs font-bold px-3 py-1.5">
            FoodPanda
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t-2 border-dashed border-[#fff4ee]/20 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[#fff4ee]/70 font-medium">
        &copy; {currentYear} Didi's Cafe & Bakery. Made with love (and butter) in Wangsa Maju.
      </p>
      <p class="text-xs text-[#fff4ee]/50">
        All photos are property of Didi's Cafe & Bakery.
      </p>
    </div>
  </div>
</footer>
